{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NDN",
  "scopeName": "source.ndn",
  "patterns": [
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "keywords": {
      "match": "\\b(let|print|interest)\\b",
      "name": "keyword.control.ndn"
    },
    "strings": {
      "name": "string.quoted.double.ndn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.ndn"
        }
      ]
    },
    "numbers": {
      "match": "-?\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.ndn"
    },
    "function-calls": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.ndn"
    },
    "operators": {
      "match": "[=*/]",
      "name": "keyword.operator.ndn"
    },
    "variables": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.ndn"
    }
  }
}
